{
  "entities": {
    "User": {
      "title": "User",
      "description": "Student or Teacher profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher"] },
        "assignedClass": { "type": "string", "description": "6-digit class code" },
        "status": { "type": "string", "enum": ["pending", "approved", "none"] }
      },
      "required": ["uid", "email", "role"]
    },
    "Class": {
      "title": "Class",
      "description": "Classroom information and current status",
      "type": "object",
      "properties": {
        "classCode": { "type": "string" },
        "teacherId": { "type": "string" },
        "isChatLocked": { "type": "boolean" },
        "currentActivity": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "endTime": { "type": "string", "format": "date-time" }
          }
        },
        "nextActivity": {
          "type": "object",
          "properties": {
            "name": { "type": "string" }
          }
        }
      },
      "required": ["classCode", "teacherId"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message in a class",
      "type": "object",
      "properties": {
        "classCode": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["classCode", "senderId", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/classes/{classCode}": {
      "schema": "Class",
      "description": "Classroom data"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Global messages filtered by classCode"
    }
  }
}
